---
import { Image } from 'astro:assets';

const data = await import('../data/portfolio.json').then(m => m.default);
const images = data.images.slice(0, 20); // First 20 for index
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width">
	<title>Stevan Kojić</title>
	<style>
		* { margin: 0; padding: 0; box-sizing: border-box; }
		body {
			font-family: 'Courier New', monospace;
			background: #ffffff;
			color: #000000;
			line-height: 1.6;
			font-size: 14px;
			padding: 40px;
		}
		a { color: #000; text-decoration: underline; }
		a:hover { background: #f0f0f0; }
		.header {
			margin-bottom: 40px;
			border-bottom: 1px solid #000;
			padding-bottom: 20px;
		}
		.nav {
			display: flex;
			gap: 20px;
			margin-bottom: 20px;
			font-size: 13px;
		}
		.nav a { text-decoration: none; }
		.nav a:hover { text-decoration: underline; }
		.title { font-size: 24px; font-weight: bold; margin-bottom: 10px; }
		.section { margin-bottom: 60px; }
		.section-title {
			font-size: 16px;
			font-weight: bold;
			margin-bottom: 20px;
			text-transform: lowercase;
			border-bottom: 1px solid #000;
			padding-bottom: 10px;
		}
		.gallery {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
			gap: 20px;
			margin-bottom: 40px;
		}
		.gallery-item { border: 1px solid #ccc; }
		.gallery-item img {
			width: 100%;
			height: auto;
			display: block;
		}
		.gallery-item-title {
			padding: 10px;
			font-size: 12px;
			background: #f9f9f9;
		}
		.text-content {
			white-space: pre-wrap;
			font-size: 13px;
			line-height: 1.5;
		}
		.footer {
			margin-top: 80px;
			padding-top: 20px;
			border-top: 1px solid #000;
			font-size: 12px;
		}
	</style>
</head>
<body>
	<div class="header">
		<div class="title">stevan kojić</div>
		<div class="nav">
			<a href="./">works</a>
			<a href="./about">about</a>
			<a href="./video">video</a>
		</div>
	</div>

	<div class="section">
		<div class="section-title">gallery</div>
		<div class="gallery">
			{images.map(img => (
				<div class="gallery-item">
					<img src={`./images/${img.file}`} alt="" loading="lazy">
					<div class="gallery-item-title">{img.file.replace(/\.\w+$/, '').substring(0, 40)}...</div>
				</div>
			))}
		</div>
	</div>

	<div class="footer">
		<a href="mailto:stevankojic.com@gmail.com">stevankojic.com@gmail.com</a><br>
		<a href="https://stevankojic.com">https://stevankojic.com</a>
	</div>
</body>
</html>
