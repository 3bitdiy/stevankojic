---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const img = (file) => base.replace(/\/$/, '') + '/images/' + file;
const linkHref = (l) => (/^https?:\/\//.test(l) ? l : 'https://' + l);

// The recurring cycle name is not a useful per-work heading — it repeats on
// almost every work. So: heading = the work's own title if it has a distinct
// one, otherwise the exhibition/venue. The cycle itself is explained in About.
const CYCLE = 'self-sustaining system of absurdity';
const isCycle = (t) => (t || '').trim().toLowerCase() === CYCLE;

const works = (await getCollection('works'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// pre-render each work's markdown body (the description)
const rendered = await Promise.all(
	works.map(async (w) => ({ data: w.data, Content: (await w.render()).Content }))
);
---

<Layout title="Stevan Kojić" active="works">
	<div class="content">
		{rendered.map(({ data, Content }) => {
			const distinct = !isCycle(data.title);
			const heading = distinct ? data.title : data.venue;
			// Exhibition name on its own line, but only when it wasn't already
			// used as the heading (i.e. for works with a distinct title).
			const exhibition = distinct ? data.venue : '';
			const placeYear = [data.location, data.year].filter(Boolean).join(', ');
			return (
			<article class="work">
				<div class="text-limit work-text">
					{heading && <h1>{heading}</h1>}
					{exhibition && <p class="venue">{exhibition}</p>}
					{placeYear && <p class="venue place">{placeYear}</p>}
					{data.medium && <p class="medium">{data.medium}</p>}
					{data.link && <p class="link"><a href={linkHref(data.link)} target="_blank" rel="noopener">{data.link}</a></p>}
					<div class="bodycopy"><Content /></div>
				</div>

				<div class="work-media">
					{data.video && (
						<div class="video-embed">
							<iframe
								src={`https://www.youtube.com/embed/${data.video}?rel=0`}
								title={data.title}
								frameborder="0"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
							></iframe>
						</div>
					)}
					{data.images.map((file) => (
						<figure class="thumbnail">
							<img src={img(file)} alt={data.title} loading="lazy" />
						</figure>
					))}
				</div>
			</article>
			);
		})}
	</div>
</Layout>

<style>
	.work {
		margin-bottom: 8rem;
	}
	.work-text {
		margin-bottom: 2rem;
	}
	/* Heading: work's own title, or the venue for cycle works. Kept at 1.6rem
	   (same as the site name) so it never dominates. */
	.work-text h1 {
		font-size: 1.6rem;
		font-weight: 400;
		line-height: 1.3;
		color: rgba(0,0,0,0.85);
		margin-bottom: 0.3rem;
	}
	.venue {
		font-size: 1.4rem;
		color: rgba(38,38,38,0.8);
		line-height: 1.4;
	}
	.venue.place {
		color: rgba(38,38,38,0.6);
	}
	.medium {
		font-size: 1.2rem;
		color: rgba(38,38,38,0.6);
		margin-top: 0.2rem;
	}
	.link {
		font-size: 1.2rem;
		margin-top: 0.2rem;
	}
	.link a { color: rgba(38,38,38,0.6); }
	.work-text .bodycopy {
		margin-top: 1.4em;
	}
	.work-text .bodycopy :global(p) {
		margin-bottom: 1.4em;
	}

	/* media: large, left-aligned like the text, Cargo-style 60% width */
	.work-media {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}
	.thumbnail {
		width: 60%;
		margin: 0 0 1rem 0;
	}
	.thumbnail img {
		display: block;
		width: 100%;
		height: auto;
	}
	.video-embed {
		position: relative;
		width: 60%;
		padding-bottom: 33.75%; /* 56.25% * 60% = 16:9 within 60% width */
		height: 0;
		margin: 0 0 1rem 0;
		background: #000;
	}
	.video-embed iframe {
		position: absolute;
		top: 0; left: 0;
		width: 100%; height: 100%;
	}

	@media (max-width: 768px) {
		.work { margin-bottom: 5rem; }
		.thumbnail { width: 100%; }
		.video-embed { width: 100%; padding-bottom: 56.25%; }
	}
</style>
