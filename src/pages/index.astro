---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const img = (file) => base.replace(/\/$/, '') + '/images/' + file;
const linkHref = (l) => (/^https?:\/\//.test(l) ? l : 'https://' + l);

const works = (await getCollection('works'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// pre-render each work's markdown body (the description)
const rendered = await Promise.all(
	works.map(async (w) => ({ data: w.data, Content: (await w.render()).Content }))
);
---

<Layout title="Stevan Kojić" active="works">
	<div class="content">
		{rendered.map(({ data, Content }) => (
			<article class="work">
				<div class="text-limit work-text">
					<h1>{data.title}</h1>
					<p class="meta small">
						{data.medium && <span>{data.medium}<br /></span>}
						{[data.venue, data.location].filter(Boolean).join(', ')}{data.year ? `, ${data.year}` : ''}
						{data.link && <span><br /><a href={linkHref(data.link)} target="_blank" rel="noopener">{data.link}</a></span>}
					</p>
					<div class="bodycopy"><Content /></div>
				</div>

				<div class="work-media">
					{data.video && (
						<div class="video-embed">
							<iframe
								src={`https://www.youtube.com/embed/${data.video}?rel=0`}
								title={data.title}
								frameborder="0"
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
								allowfullscreen
							></iframe>
						</div>
					)}
					{data.images.map((file) => (
						<figure class="thumbnail">
							<img src={img(file)} alt={data.title} loading="lazy" />
						</figure>
					))}
				</div>
			</article>
		))}
	</div>
</Layout>

<style>
	.work {
		margin-bottom: 8rem;
	}
	.work-text {
		margin-bottom: 2rem;
	}
	.work-text h1 {
		margin-bottom: 0.4rem;
	}
	.meta {
		color: rgba(38,38,38,0.85);
		line-height: 1.4;
		margin-bottom: 1.4em;
	}
	.work-text .bodycopy :global(p) {
		margin-bottom: 1.4em;
	}

	/* media: large, left-aligned like the text, Cargo-style 60% width */
	.work-media {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}
	.thumbnail {
		width: 60%;
		margin: 0 0 1rem 0;
	}
	.thumbnail img {
		display: block;
		width: 100%;
		height: auto;
	}
	.video-embed {
		position: relative;
		width: 60%;
		padding-bottom: 33.75%; /* 56.25% * 60% = 16:9 within 60% width */
		height: 0;
		margin: 0 0 1rem 0;
		background: #000;
	}
	.video-embed iframe {
		position: absolute;
		top: 0; left: 0;
		width: 100%; height: 100%;
	}

	@media (max-width: 768px) {
		.work { margin-bottom: 5rem; }
		.thumbnail { width: 100%; }
		.video-embed { width: 100%; padding-bottom: 56.25%; }
	}
</style>
