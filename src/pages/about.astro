---
const data = await import('../data/portfolio.json').then(m => m.default);
const about = data.about;
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width">
	<title>About - Stevan Kojić</title>
	<style>
		* { margin: 0; padding: 0; box-sizing: border-box; }
		body {
			font-family: 'Courier New', monospace;
			background: #ffffff;
			color: #000000;
			line-height: 1.6;
			font-size: 14px;
			padding: 40px;
			max-width: 900px;
		}
		a { color: #000; text-decoration: underline; }
		a:hover { background: #f0f0f0; }
		.header {
			margin-bottom: 40px;
			border-bottom: 1px solid #000;
			padding-bottom: 20px;
		}
		.nav {
			display: flex;
			gap: 20px;
			margin-bottom: 20px;
			font-size: 13px;
		}
		.nav a { text-decoration: none; }
		.nav a:hover { text-decoration: underline; }
		.title { font-size: 24px; font-weight: bold; margin-bottom: 10px; }
		.section { margin-bottom: 40px; }
		.section-title {
			font-size: 14px;
			font-weight: bold;
			margin-bottom: 15px;
			text-transform: lowercase;
			border-bottom: 1px solid #000;
			padding-bottom: 8px;
		}
		.text-content {
			white-space: pre-wrap;
			font-size: 13px;
			line-height: 1.6;
			margin-bottom: 20px;
		}
		.footer {
			margin-top: 60px;
			padding-top: 20px;
			border-top: 1px solid #000;
			font-size: 12px;
		}
	</style>
</head>
<body>
	<div class="header">
		<div class="title">stevan kojić</div>
		<div class="nav">
			<a href="/">works</a>
			<a href="/about">about</a>
			<a href="/video">video</a>
		</div>
	</div>

	<div class="section">
		<div class="section-title">artist statement</div>
		<div class="text-content">{about.statement}</div>
	</div>

	{about.cv && (
		<div class="section">
			<div class="section-title">cv</div>
			<div class="text-content">{about.cv}</div>
		</div>
	)}

	{about.group_exhibitions && (
		<div class="section">
			<div class="section-title">group exhibitions</div>
			<div class="text-content">{about.group_exhibitions}</div>
		</div>
	)}

	{about.solo_exhibitions && (
		<div class="section">
			<div class="section-title">solo exhibitions</div>
			<div class="text-content">{about.solo_exhibitions}</div>
		</div>
	)}

	{about.awards && (
		<div class="section">
			<div class="section-title">awards</div>
			<div class="text-content">{about.awards}</div>
		</div>
	)}

	<div class="footer">
		<a href="mailto:stevankojic.com@gmail.com">stevankojic.com@gmail.com</a><br>
		<a href="https://stevankojic.com">https://stevankojic.com</a>
	</div>
</body>
</html>
