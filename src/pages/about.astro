---
import Layout from '../layouts/Layout.astro';

const data = await import('../data/portfolio.json').then(m => m.default);
const about = data.about;

// Split multi-line blocks into paragraphs / lines for rendering
const paragraphs = (txt) => (txt || '').split(/\n{2,}/).map(p => p.trim()).filter(Boolean);
const lines = (txt) => (txt || '').split(/\n/).map(l => l.trim()).filter(Boolean);
const isYear = (l) => /^\d{4}$/.test(l);
---

<Layout title="About — Stevan Kojić" active="about">
	<div class="content">
		<div class="text-limit bodycopy">
			{about.statement && paragraphs(about.statement).map(p => <p>{p}</p>)}

			{about.cv && (
				<section>
					{paragraphs(about.cv).map(p => <p>{p}</p>)}
				</section>
			)}

			{about.solo_exhibitions && (
				<section class="cv-section">
					<h2>Solo Exhibitions</h2>
					{lines(about.solo_exhibitions).map(l => (
						<p class={isYear(l) ? 'year' : 'entry'}>{l}</p>
					))}
				</section>
			)}

			{about.group_exhibitions && (
				<section class="cv-section">
					<h2>Group Exhibitions</h2>
					{lines(about.group_exhibitions).map(l => (
						<p class={isYear(l) ? 'year' : 'entry'}>{l}</p>
					))}
				</section>
			)}

			{about.awards && (
				<section class="cv-section">
					<h2>Awards</h2>
					{lines(about.awards).map(l => (
						<p class={isYear(l) ? 'year' : 'entry'}>{l}</p>
					))}
				</section>
			)}

			<section class="cv-section">
				<p><a href="mailto:stevankojic.com@gmail.com">stevankojic.com@gmail.com</a></p>
			</section>
		</div>
	</div>
</Layout>

<style>
	.cv-section { margin-top: 3rem; }
	.cv-section h2 { margin-bottom: 1rem; }
	.cv-section .year { margin-top: 1.4em; margin-bottom: 0.2em; color: rgba(0,0,0,0.85); }
	.cv-section .entry { margin-bottom: 0; line-height: 1.4; }
</style>
